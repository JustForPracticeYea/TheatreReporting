@page "/performances/{PlayId:int}"
@rendermode InteractiveServer
@using AntDesign.TableModels
@using System.ComponentModel.DataAnnotations
@using System.ComponentModel
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@using TheatreReportingApp.Models
@using TheatreReportingApp.Models.Enums
@inject ModalService ModalService;
@inject ConfirmService ComfirmService;
@inject TheatreDbContext _context;
@inject NavigationManager Navigation
@attribute [Authorize]


<PageHeader Class="site-page-header" Title="Проведенные спектакли" />
<div class="controls-container">
    <a @onclick="() => GoBack()" class="back-button">
        <Icon Type="arrow-left" Width="37px" Height="37px" />
    </a>

    <div class="d-flex align-items-center gap-2 center-controls">
        <DatePicker TValue="DateTime?"
                    CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")"
                    class="date-filter" />
        <a @onclick="() => AddPerformance()" class="add-button">
            <Icon Type="plus-square" Width="37px" Height="37px" />
        </a>
        <a @onclick="() => EditPlay()" class="add-button">
            <Icon Type="form" Width="37px" Height="37px" />
        </a>
    </div>

    <div style="width: 37px;"></div>
</div>

<Table @ref="_performanceTable" TItem="Performance" PageSize="10" Total="_performanceTotal" DataSource="_performanceDataSource" OnChange="OnPerformanceChange">
    <PropertyColumn Property="p => p.PerformanceNumber"></PropertyColumn>
    <PropertyColumn Property="p => p.Type">
        <Template>
            @(
                context.Type switch
                {
                    PerformanceType.Stationary => "Стационар",
                    PerformanceType.OnSite => "Выезд",
                    PerformanceType.Tour => "Гастроль",
                    _ => context.Type.ToString()
                }
                )
        </Template>
    </PropertyColumn>
    <PropertyColumn Property="p => p.EventDateTime" Format="dd-MM-yyyy"></PropertyColumn>
    <ActionColumn>
        <a @onclick="() => EditPerformance(context.PerformanceId)"><Icon Type="form" Height="2em" Width="2em" /></a>
        <a><Icon Type="delete" Height="2em" Width="2em" /></a>
    </ActionColumn>
</Table>

<PlayModal @bind-Visible="@_isModalVisible" IsEdit="true" OnSuccess="OnPlayEdited" EditPlay="_editPlay"/>

@code {
    [Parameter]
    public int PlayId { get; set; }

    public ITable _performanceTable;

    List<Performance> _performanceDataSource = new();
    int _performanceTotal;
    private QueryModel<Performance> _currentPerformanceQuery;
    private bool _isModalVisible = false;
    private Play? _editPlay;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlayData();
        await LoadPerformanceData();
    }

    private async Task LoadPlayData()
    {
        _editPlay = await _context.Plays
            .Include(p => p.PlayAuthors)
            .FirstOrDefaultAsync(p => p.PlayId == PlayId);
    }

    async Task OnPerformanceChange(QueryModel<Performance> query)
    {
        _currentPerformanceQuery = query;
        await LoadPerformanceData(query);
    }

    private async Task<List<Performance>> GetAllPerformanceAsync()
    {
        var performances = await _context.Performances
                                   .Include(p => p.Play)
                                   .ThenInclude(p => p.PlayAuthors)
                                   .ThenInclude(p => p.Authors)
                                   .Where(p => p.PlayId == PlayId)
                                   .OrderByDescending(p => p.EditDate)
                                   .ToListAsync();

        return performances;
    }

    private async Task LoadPerformanceData(QueryModel<Performance> query = null)
    {
        var allPerformance = await GetAllPerformanceAsync();
        _performanceTotal = allPerformance.Count;

        if (query != null)
        {
            var queryable = allPerformance.AsQueryable();

            _performanceDataSource = queryable
                .Skip(query.PageSize * (query.PageIndex - 1))
                .Take(query.PageSize)
                .ToList();
        }
        else
        {
            _performanceDataSource = allPerformance.Take(10).ToList();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void EditPerformance(int performanceId)
    {
        Navigation.NavigateTo($"{PlayId}/EditPerformance/{performanceId}");
    }
    private void AddPerformance()
    {
        Navigation.NavigateTo($"{PlayId}/AddPerformance");
    }
    private void GoBack()
    {
        Navigation.NavigateTo("/Plays");
    }

    private void EditPlay()
    {
        _isModalVisible = true;
    }

    private async Task OnPlayEdited()
    {
        _isModalVisible = false;
        await LoadPlayData();
        StateHasChanged();
    }
}