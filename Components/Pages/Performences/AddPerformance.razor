        await LoadTourCityOptions(value);
    }

    private async void OnTourCitySelected(string value)
    {
        if (performance.TourType == "International")
        {
            var parts = value.Split(',');
            if (parts.Length >= 2)
            {
                performance.TourTownName = parts[0].Trim();
                performance.Country = parts[1].Trim();
            }
        }
        else
        {
            performance.TourTownName = value;
            performance.Country = "Россия";
        }
