@page "/{PlayId:int}/AddPerformance"
@rendermode InteractiveServer
@using System.Globalization
@using ClosedXML.Excel
@using TheatreReportingApp.DtoAndHelpers
@using TheatreReportingApp.Models
@using TheatreReportingApp.Models.Enums
@inject TheatreDbContext _context
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3 class="text-center">Добавление спектакля</h3>
<div class="form-container">
    <div class="form-wrapper">
        <EditForm Model="@performance" OnValidSubmit="@CreateNewPerformance">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <Alert Type="AlertType.Error" Message="@errorMessage" Banner Class="mb-3" />
            }

            <label class="ant-btn ant-btn-dashed mb-3" style="cursor:pointer;">
                <Icon Type="upload" /> Заполнить из Excel
                <InputFile OnChange="HandleFileUpload" accept=".xlsx, .xls" style="display:none;" />
            </label>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Номер спектакля</label>
                        <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.PerformanceNumber" />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Тип проведения</label>
                        <InputSelect class="form-control" @bind-Value="performance.Type">
                            <option value="Stationary">Стационар</option>
                            <option value="OnSite">Выезд</option>
                            <option value="Tour">Гастроли</option>
                        </InputSelect>
                    </div>
                </div>
            </div>

            @if (performance.Type == PerformanceType.Stationary)
            {
                <div class="form-group mb-3">
                    <label>Место проведения</label>
                    <InputSelect class="form-control" @bind-Value="performance.StationaryId">
                        @foreach (var loc in stationaryLocations)
                        {
                            <option value="@loc.StationarId">@loc.LocationName</option>
                        }
                    </InputSelect>
                </div>
            }

            @if (performance.Type == PerformanceType.OnSite)
            {
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Тип населенного пункта</label>
                            <InputSelect class="form-control" @bind-Value="performance.SettlementType">
                                <option value="City">Город</option>
                                <option value="Village">Село</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Название</label>
                            <AutoComplete class="form-control"
                                Placeholder="Введите название..."
                                Options="@onSiteNameOptions"
                                @bind-Value="performance.OnSiteTownName"
                                OnInput="@(v => OnSiteNameInput(v.Value?.ToString()))"
                                OnSelectionChange="@(v => OnSiteNameSelected(v.Label))" />
                        </div>
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label>Регион</label>
                    <AutoComplete class="form-control"
                        Placeholder="Введите регион..."
                        Options="@regionOptions"
                        @bind-Value="performance.Region"
                        OnInput="@(v => OnRegionInput(v.Value?.ToString()))"
                        OnSelectionChange="@(v => OnRegionSelected(v.Label))" />
                </div>
            }

            @if (performance.Type == PerformanceType.Tour)
            {
                <div class="form-group mb-3">
                    <label>Тип гастролей</label>
                    <InputSelect class="form-control" @bind-Value="performance.TourType" @onchange="OnTourTypeChanged">
                        <option value="Home">По России</option>
                        <option value="International">Зарубеж</option>
                    </InputSelect>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Город</label>
                            <AutoComplete class="form-control"
                                          Placeholder="Введите город..."
                                          Options="@tourCityOptions"
                                          Value="@performance.TourTownName"
                                          OnInput="@(e => OnTourCityInput(e.Value?.ToString()))"
                                          OnSelectionChange="@(v => OnTourCitySelected(v.Label))" />
                        </div>
                    </div>
                    @if (performance.TourType == "International")
                    {
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Страна</label>
                                <AutoComplete class="form-control"
                                              Placeholder="Введите страну..."
                                              Options="@countryOptions"
                                              Value="@performance.Country"
                                              OnInput="@(e => OnCountryInput(e.Value?.ToString()))"
                                              OnSelectionChange="@(v => OnCountrySelected(v.Label))" />
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Дата проведения спектакля</label>
                        <AntDesign.DatePicker class="form-control w-50"
                                              DefaultValue="DateTime.Now"
                                              CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")" 
                                              @bind-Value="performance.SelectedDate"/>
                        <ValidationMessage For="@(() => performance.SelectedDate)" />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Время проведения спектакля</label>
                        <TimePicker class="form-control w-50"
                                    ChangeOnClose="true"
                                    TValue="DateTime?"
                                    Picker="DatePickerType.Time"
                                    Format="HH:mm"
                                    CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")"
                                    @bind-Value="performance.SelectedTime"
                                    OnValueChanged="@OnTimeChanged" />
                        <ValidationMessage For="@(() => performance.SelectedTime)" />
                    </div>
                 </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Продажа билетов на кассе</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickNonCashOffice" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Продажа билетов через интернет</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickNonCashOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Возвраты билетов</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetNonCashOline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Реализованные билеты (касса/интернет)</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldNonCashOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Итоговые суммы (касса/интернет)</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого билетов (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllNumTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого сумма (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllAmountTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого билетов (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllNumTickSoldOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого сумма (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllAmountTickSoldOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Реально получено (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.RealAmountTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Реально получено (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.RealAmountTickSoldInOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Итоги нал/безнал (касса + интернет)</h5>
                </div>
                <div class="card-body">
                    <h5>Продано</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldNonCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldNonCashInOfficeOnline" />
                            </div>
                        </div>
                    </div>
                    <h5 class="mt-3">Возвраты</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего возвратов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickRetCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма возвратов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountFundsRetCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего возвратов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickRetNonCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма возвратов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountFundsRetNonCashInOfficeOnline" />
                            </div>
                        </div>
                    </div>
                    <h5 class="mt-3">Реализовано</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldNonCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldNonCashOfficeOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Общий итог</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAllNumTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAllAmountTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего реально получено</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalRealAmountTickSoldInOfficeOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Аншлаг и проценты</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Аншлаг (всего мест)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.Capacity" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Максимальная сумма при аншлаге</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.MaxRevenue" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Остаток мест</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.RemainingCapacity" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма за остаток билетов</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.RemainingRevenue" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Процент реализации билетов</label>
                                <AntDesign.InputNumber Min="0" Max="100" Step="0.1" class="form-control" @bind-Value="performance.TicketImplementationPercentage" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Процент реализации средств</label>
                                <AntDesign.InputNumber Min="0" Max="100" Step="0.1" class="form-control" @bind-Value="performance.AmountImplementationPercentage" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-white">Категории зрителей (бесплатно)</h5>
                </div>
                <div class="card-body">
                    @if (performanceViewerCategories.Any())
                    {
                        foreach (var category in performanceViewerCategories)
                        {
                            <div class="row mb-2 align-items-center">
                                <div class="col-md-4">
                                    <label>Категория зрителей</label>
                                    <div class="form-group mb-0">
                                        
                                        <InputSelect class="form-control" @bind-Value="category.ViewerCategoryId">
                                            <option value="0" disabled selected>Выберите категорию</option>
                                            @foreach (var vc in viewerCategoriesList)
                                            {
                                                <option value="@vc.ViewerCategoryId">@vc.CategoryName</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label>Кол-во зрителей</label>
                                    <div class="form-group mb-0">
                                        <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="category.ViewerCount" />
                                    </div>
                                </div>
                                <div class="col-md-1">
                                    <button type="button" class="btn btn-sm" @onclick="() => RemoveViewerCategory(category)">
                                        <Icon Type="delete" Height="2em" Width="2em" />
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Нет добавленных категорий</p>
                    }
                    @if (performanceViewerCategories.Count < viewerCategoriesList.Count)
                    {
                        <button type="button" class="btn btn-sm" @onclick="AddViewerCategory">
                            <Icon Type="plus" /> Добавить категорию
                        </button>
                    }
                </div>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a class="btn btn-secondary ms-2" @onclick="Cancel">Отмена</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int PlayId { get; set; }
    private PerformanceDto performance = new PerformanceDto();

    private List<ViewerCategory> viewerCategoriesList = new();
    private List<PerformanceViewerCategory> performanceViewerCategories = new();

    private List<StationarLocation> stationaryLocations = new();
    private List<string> onSiteNameOptions = new();
    private List<string> regionOptions = new();

    private List<string> tourCityOptions = new();
    private List<string> countryOptions = new();

    private InputFile? fileInput;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        performance.Type = PerformanceType.Stationary;
        performance.StationaryId = 1;
        performance.SettlementType = SettlementType.City;
        performance.TourType = "Home";
        stationaryLocations = await _context.StationarLocations.ToListAsync();
        viewerCategoriesList = await _context.ViewerCategories.ToListAsync();
    }

    private void AddViewerCategory()
    {
        if (performanceViewerCategories.Count >= viewerCategoriesList.Count) 
            return;
        performanceViewerCategories.Add(new PerformanceViewerCategory());
    }

    private void RemoveViewerCategory(PerformanceViewerCategory category)
    {
        performanceViewerCategories.Remove(category);
    }

    private void OnTimeChanged(DateTime? dateTime)
    {
        if (dateTime.HasValue)
        {
            performance.SelectedTime = dateTime;
            StateHasChanged();
        }
    }

    private void OnTourTypeChanged(ChangeEventArgs e)
    {
        performance.TourType = e.Value?.ToString();
        performance.TourTownName = null;
        performance.Country = null;
    }

    private async Task LoadOnSiteNameOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            onSiteNameOptions = await _context.OnSiteLocations
                .Where(l => EF.Functions.Like(l.TownName, search + "%"))
                .Select(l => l.TownName + ", " + l.Region + " (" + (l.SettlementType == SettlementType.City ? "Город" : "Село") + ")")
                .Distinct()
                .Take(10)
                .ToListAsync();
        }
        else
            onSiteNameOptions.Clear();
    }

    private async Task LoadRegionOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            regionOptions = await _context.OnSiteLocations
                .Where(l => EF.Functions.Like(l.Region, search + "%"))
                .Select(l => l.Region)
                .Distinct()
                .Take(10)
                .ToListAsync();
        }
        else
            regionOptions.Clear();
    }

    private async void OnSiteNameInput(string value)
    {
        performance.OnSiteTownName = value;
        await LoadOnSiteNameOptions(value);
    }

    private void OnSiteNameSelected(string value)
    {
        var parts = value.Split(',');
        if (parts.Length >= 2)
        {
            performance.OnSiteTownName = parts[0].Trim();
            performance.Region = parts[1].Split('(')[0].Trim();
            performance.SettlementType = value.Contains("(Город)") ? SettlementType.City : SettlementType.Village;
        }
    }

    private async void OnRegionInput(string value)
    {
        performance.Region = value;
        await LoadRegionOptions(value);
    }

    private async void OnRegionSelected(string value)
    {
        performance.Region = value;
    }

    private async Task LoadTourCityOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {

            if (performance.TourType == "International")
            {
                tourCityOptions = await _context.TourLocations
                    .Where(l => EF.Functions.Like(l.TownName, search + "%") && l.Country != "Россия")
                    .Select(l => l.TownName + ", " + l.Country)
                    .Distinct()
                    .Take(10)
                    .ToListAsync();
            }
            else
            {
                tourCityOptions = await _context.TourLocations
                    .Where(l => EF.Functions.Like(l.TownName, search + "%") && l.Country == "Россия")
                    .Select(l => l.TownName)
                    .Distinct()
                    .Take(10)
                    .ToListAsync();
            }
        }
        else
            tourCityOptions.Clear();
    }

    private async Task LoadCountryOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            countryOptions = await _context.TourLocations
                .Where(l => EF.Functions.Like(l.Country, search + "%") && l.Country != "Россия")
                .Select(l => l.Country)
                .Distinct()
                .Take(10)
                .ToListAsync();
        }
        else
            countryOptions.Clear();
    }

    private async void OnTourCityInput(string value)
    {
        performance.TourTownName = value;
        await LoadTourCityOptions(value);
    }

    private async void OnTourCitySelected(string value)
    {
        if (performance.TourType == "International")
        {
            var parts = value.Split(',');
            if (parts.Length >= 2)
            {
                performance.TourTownName = parts[0].Trim();
                performance.Country = parts[1].Trim();
            }
        }
        else
        {
            performance.TourTownName = value;
            performance.Country = "Россия";
        }
    }

    private async void OnCountryInput(string value)
    {
        performance.Country = value;
        await LoadCountryOptions(value);
    }

    private async void OnCountrySelected(string value)
    {
        performance.Country = value;
    }

    private async Task<string> GetCurrentUserId()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        return user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    }

    private async Task CreateNewPerformance()
    {
        var eventDateTime = performance.SelectedDate.Date + performance.SelectedTime.Value.TimeOfDay;
        var userId = await GetCurrentUserId();

        if (performance.Type == PerformanceType.OnSite)
        {
            var nameLower = performance.OnSiteTownName;
            var loc = await _context.OnSiteLocations.FirstOrDefaultAsync(l =>EF.Functions.Like(l.TownName, performance.OnSiteTownName) && 
                                                                         l.SettlementType == performance.SettlementType && 
                                                                         l.Region == performance.Region);
            if (loc == null)
            {
                loc = new OnSiteLocation { TownName = performance.OnSiteTownName, SettlementType = performance.SettlementType, Region = performance.Region };
                _context.OnSiteLocations.Add(loc);
                await _context.SaveChangesAsync();
            }
            performance.OnSiteId = loc.OnSiteId;
        }
        else if (performance.Type == PerformanceType.Tour)
        {
            var country = performance.TourType == "Home" ? "Россия" : performance.Country;
            var loc = await _context.TourLocations
                .FirstOrDefaultAsync(l => EF.Functions.Like(l.TownName, performance.TourTownName)
                                       && EF.Functions.Like(l.Country, country));
            if (loc == null)
            {
                loc = new TourLocation 
                { 
                    TownName = performance.TourTownName, 
                    Country = country 
                };
                _context.TourLocations.Add(loc);
                await _context.SaveChangesAsync();
            }
            performance.TourId = loc.TourId;
        }

        if (performance.Type != PerformanceType.Stationary)
            performance.StationaryId = null;
        if (performance.Type != PerformanceType.OnSite)
            performance.OnSiteId = null;
        if (performance.Type != PerformanceType.Tour)
            performance.TourId = null;

        var newPerformance = new Performance
        {
            PerformanceNumber = performance.PerformanceNumber,
            Type = performance.Type,
            StationaryId = performance.StationaryId,
            OnSiteId = performance.OnSiteId,
            TourId = performance.TourId,
            EventDateTime = eventDateTime,

            NumTickCashOffice = performance.NumTickCashOffice,
            NumTickNonCashOffice = performance.NumTickNonCashOffice,
            NumTickCashOnline = performance.NumTickCashOnline,
            NumTickNonCashOnline = performance.NumTickNonCashOnline,
            AmountTickCashOffice = performance.AmountTickCashOffice,
            AmountTickNonCashOffice = performance.AmountTickNonCashOffice,
            AmountTickCashOnline = performance.AmountTickCashOnline,
            AmountTickNonCashOnline = performance.AmountTickNonCashOnline,

            NumTickRetCashOffice = performance.NumTickRetCashOffice,
            NumTickRetNonCashOffice = performance.NumTickRetNonCashOffice,
            NumTickRetCashOnline = performance.NumTickRetCashOnline,
            NumTickRetNonCashOnline = performance.NumTickRetNonCashOnline,
            AmountFundsRetCashOffice = performance.AmountFundsRetCashOffice,
            AmountFundsRetNonCashOffice = performance.AmountFundsRetNonCashOffice,
            AmountFundsRetCashOnline = performance.AmountFundsRetCashOnline,
            AmountFundsRetNonCashOline = performance.AmountFundsRetNonCashOline,

            NumTickSoldCashOffice = performance.NumTickSoldCashOffice,
            NumTickSoldNonCashOffice = performance.NumTickSoldNonCashOffice,
            NumTickSoldCashOnline = performance.NumTickSoldCashOnline,
            NumTickSoldNonCashOnline = performance.NumTickSoldNonCashOnline,
            AmountTickSoldCashOffice = performance.AmountTickSoldCashOffice,
            AmountTickSoldNonCashOffice = performance.AmountTickSoldNonCashOffice,
            AmountTickSoldCashOnline = performance.AmountTickSoldCashOnline,
            AmountTickSoldNonCashOnline = performance.AmountTickSoldNonCashOnline,

            AllNumTickSoldInOffice = performance.AllNumTickSoldInOffice,
            AllNumTickSoldOnline = performance.AllNumTickSoldOnline,
            AllAmountTickSoldInOffice = performance.AllAmountTickSoldInOffice,
            AllAmountTickSoldOnline = performance.AllAmountTickSoldOnline,
            RealAmountTickSoldInOffice = performance.RealAmountTickSoldInOffice,
            RealAmountTickSoldInOnline = performance.RealAmountTickSoldInOnline,

            TotalNumTickSoldCashInOfficeOnline = performance.TotalNumTickSoldCashInOfficeOnline,
            TotalAmountTickSoldCashInOfficeOnline = performance.TotalAmountTickSoldCashInOfficeOnline,
            TotalNumTickSoldNonCashInOfficeOnline = performance.TotalNumTickSoldNonCashInOfficeOnline,
            TotalAmountTickSoldNonCashInOfficeOnline = performance.TotalAmountTickSoldNonCashInOfficeOnline,

            TotalNumTickRetCashInOfficeOnline = performance.TotalNumTickRetCashInOfficeOnline,
            TotalAmountFundsRetCashInOfficeOnline = performance.TotalAmountFundsRetCashInOfficeOnline,
            TotalNumTickRetNonCashInOfficeOnline = performance.TotalNumTickRetNonCashInOfficeOnline,
            TotalAmountFundsRetNonCashInOfficeOnline = performance.TotalAmountFundsRetNonCashInOfficeOnline,

            TotalNumTickSoldCashOfficeOnline = performance.TotalNumTickSoldCashOfficeOnline,
            TotalAmountTickSoldCashOfficeOnline = performance.TotalAmountTickSoldCashOfficeOnline,
            TotalNumTickSoldNonCashOfficeOnline = performance.TotalNumTickSoldNonCashOfficeOnline,
            TotalAmountTickSoldNonCashOfficeOnline = performance.TotalAmountTickSoldNonCashOfficeOnline,

            TotalAllNumTickSoldInOfficeOnline = performance.TotalAllNumTickSoldInOfficeOnline,
            TotalAllAmountTickSoldInOfficeOnline = performance.TotalAllAmountTickSoldInOfficeOnline,
            TotalRealAmountTickSoldInOfficeOnline = performance.TotalRealAmountTickSoldInOfficeOnline,

            Capacity = performance.Capacity,
            MaxRevenue = performance.MaxRevenue,
            RemainingCapacity = performance.RemainingCapacity,
            RemainingRevenue = performance.RemainingRevenue,
            TicketImplementationPercentage = performance.TicketImplementationPercentage,
            AmountImplementationPercentage = performance.AmountImplementationPercentage,

            EditDate = DateTime.Now,
            UserId = userId,

            PlayId = PlayId
        };

        _context.Performances.Add(newPerformance);
        await _context.SaveChangesAsync();


        foreach (var category in performanceViewerCategories.Where(c => c.ViewerCategoryId > 0 && c.ViewerCount > 0))
        {
            category.PerformanceId = newPerformance.PerformanceId;
            _context.PerformanceViewerCategories.Add(category);
        }
        await _context.SaveChangesAsync();
        Navigation.NavigateTo($"/performances/{PlayId}");
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        var file = e.File;
        if (file == null) 
            return;

        using var memoryStream = new MemoryStream();
        await file.OpenReadStream().CopyToAsync(memoryStream);
        memoryStream.Position = 0;

        using var workbook = new XLWorkbook(memoryStream);
        var ws = workbook.Worksheet(1);

        var fullLine = string.Join(" ", ws.Row(4).CellsUsed().Select(c => c.GetValue<string>()));

        // Проверка названия
        var titleMatch = System.Text.RegularExpressions.Regex.Match(fullLine, @"^(.+?)\s*\(");
        if (titleMatch.Success)
        {
            var excelTitle = titleMatch.Groups[1].Value.Trim();
            var currentPlay = await _context.Plays.FindAsync(PlayId);

            if (currentPlay == null || !excelTitle.Equals(currentPlay.Title, StringComparison.OrdinalIgnoreCase))
            {
                errorMessage = $"Название в Excel («{excelTitle}») не совпадает с текущим спектаклем («{currentPlay?.Title}»)";
                StateHasChanged();
                return;
            }
        }

        // Номер мероприятия
        var numberMatch = System.Text.RegularExpressions.Regex.Match(fullLine, @"№\s*мер-ия\s*(\d+)");
        if (numberMatch.Success)
            performance.PerformanceNumber = int.Parse(numberMatch.Groups[1].Value);

        // Время
        var timeMatch = System.Text.RegularExpressions.Regex.Match(fullLine, @"(\d{2}:\d{2})");
        if (timeMatch.Success)
            performance.SelectedTime = DateTime.ParseExact(timeMatch.Groups[1].Value, "HH:mm", null);

        // Дата
        var dateMatch = System.Text.RegularExpressions.Regex.Match(fullLine, @"(\d{2}\.\d{2}\.\d{4})");
        if (dateMatch.Success)
            performance.SelectedDate = DateTime.ParseExact(dateMatch.Groups[1].Value, "dd.MM.yyyy", null);

        // Сцена
        var sceneMatch = System.Text.RegularExpressions.Regex.Match(fullLine, @"сцена\s*:\s*([^)]+)\)");
        if (sceneMatch.Success)
        {
            var sceneName = sceneMatch.Groups[1].Value.Trim();
            var loc = stationaryLocations.FirstOrDefault(s => s.LocationName == sceneName);
            if (loc != null)
            {
                performance.StationaryId = loc.StationarId;
                performance.Type = PerformanceType.Stationary;
            }
        }

        StateHasChanged();
    }

    private void Cancel()
    {
        Navigation.NavigateTo($"/performances/{PlayId}");
    }
}