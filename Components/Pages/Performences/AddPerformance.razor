@page "/{PlayId:int}/AddPerformance"
@rendermode InteractiveServer
@using System.Globalization
@using TheatreReportingApp.DtoAndHelpers
@using TheatreReportingApp.Models
@inject TheatreDbContext _context
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3 class="text-center">Добавление спектакля</h3>
<div class="form-container">
    <div class="form-wrapper">
        <EditForm Model="@performance" OnValidSubmit="@CreateNewPerformance">
            <DataAnnotationsValidator />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Номер спектакля</label>
                        <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.PerformanceNumber" />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Тип проведения</label>
                        <InputSelect class="form-control" 
                                     @bind-Value="performance.Type" 
                                     @onchange="OnTypeChanged">
                            <option value="Стационар">Стационар</option>
                            <option value="Выезд">Выезд</option>
                            <option value="Гастроль">Гастроли</option>
                        </InputSelect>
                    </div>
                </div>
            </div>

            @if (performance.Type == "Стационар")
            {
                <div class="form-group mb-3">
                    <label>Место проведения</label>
                    <InputSelect class="form-control" @bind-Value="performance.StationaryId">
                        @foreach (var loc in stationaryLocations)
                        {
                            <option value="@loc.StationarId">@loc.LocationName</option>
                        }
                    </InputSelect>
                </div>
            }

            @if (performance.Type == "Выезд")
            {
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Тип населенного пункта</label>
                            <InputSelect class="form-control" @bind-Value="performance.SettlementType">
                                <option value="Город">Город</option>
                                <option value="Село">Село</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Название</label>
                            <AutoComplete class="form-control"
                                Placeholder="Введите название..."
                                Options="@onSiteNameOptions"
                                @bind-Value="performance.OnSiteTownName"
                                OnInput="@(v => OnSiteNameInput(v.Value?.ToString()))"
                                OnSelectionChange="@(v => OnSiteNameSelected(v.Label))" />
                        </div>
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label>Регион</label>
                    <AutoComplete class="form-control"
                        Placeholder="Введите регион..."
                        Options="@regionOptions"
                        @bind-Value="performance.Region"
                        OnInput="@(v => OnRegionInput(v.Value?.ToString()))"
                        OnSelectionChange="@(v => OnRegionSelected(v.Label))" />
                </div>
            }

            @if (performance.Type == "Гастроль")
            {
                <div class="form-group mb-3">
                    <label>Тип гастролей</label>
                    <InputSelect class="form-control" @bind-Value="performance.TourType" @onchange="OnTourTypeChanged">
                        <option value="Home">По России</option>
                        <option value="International">Зарубеж</option>
                    </InputSelect>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Город</label>
                            <AutoComplete class="form-control"
                                          Placeholder="Введите город..."
                                          Options="@tourCityOptions"
                                          Value="@performance.TourTownName"
                                          OnInput="@(e => OnTourCityInput(e.Value?.ToString()))"
                                          OnSelectionChange="@(v => OnTourCitySelected(v.Label))" />
                        </div>
                    </div>
                    @if (performance.TourType == "International")
                    {
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Страна</label>
                                <AutoComplete class="form-control"
                                              Placeholder="Введите страну..."
                                              Options="@countryOptions"
                                              Value="@performance.Country"
                                              OnInput="@(e => OnCountryInput(e.Value?.ToString()))"
                                              OnSelectionChange="@(v => OnCountrySelected(v.Label))" />
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Дата проведения спектакля</label>
                        <AntDesign.DatePicker class="form-control w-50"
                                              DefaultValue="DateTime.Now"
                                              CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")" 
                                              @bind-Value="performance.SelectedDate"/>
                        <ValidationMessage For="@(() => performance.SelectedDate)" />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Время проведения спектакля</label>
                        <TimePicker class="form-control w-50"
                                    ChangeOnClose="true"
                                    TValue="DateTime?"
                                    Picker="DatePickerType.Time"
                                    Format="HH:mm"
                                    CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")"
                                    @bind-Value="performance.SelectedTime"
                                    OnValueChanged="@OnTimeChanged" />
                        <ValidationMessage For="@(() => performance.SelectedTime)" />
                    </div>
                 </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Продажа билетов на кассе</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickNonCashOffice" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Продажа билетов через интернет</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickNonCashOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Возвраты билетов</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickRetNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountFundsRetNonCashOline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Реализованные билеты (касса/интернет)</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumTickSoldNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AmountTickSoldNonCashOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Итоговые суммы (касса/интернет)</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого билетов (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllNumTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого сумма (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllAmountTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого билетов (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllNumTickSoldOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого сумма (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.AllAmountTickSoldOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Реально получено (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.RealAmountTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Реально получено (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.RealAmountTickSoldInOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Итоги нал/безнал (касса + интернет)</h5>
                </div>
                <div class="card-body">
                    <h5>Продано</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldNonCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldNonCashInOfficeOnline" />
                            </div>
                        </div>
                    </div>
                    <h5 class="mt-3">Возвраты</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего возвратов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickRetCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма возвратов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountFundsRetCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего возвратов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickRetNonCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма возвратов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountFundsRetNonCashInOfficeOnline" />
                            </div>
                        </div>
                    </div>
                    <h5 class="mt-3">Реализовано</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalNumTickSoldNonCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAmountTickSoldNonCashOfficeOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Общий итог</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAllNumTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalAllAmountTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего реально получено</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.TotalRealAmountTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6"></div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Аншлаг (всего мест)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.Capacity" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Максимальная сумма при аншлаге</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.MaxRevenue" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Зрителей бесплатно</label>
                        <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performance.NumViewrsServedFree" />
                    </div>
                </div>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a class="btn btn-secondary ms-2" @onclick="Cancel">Отмена</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int PlayId { get; set; }
    private PerformanceDto performance = new PerformanceDto();

    private List<StationarLocation> stationaryLocations = new();
    private List<string> onSiteNameOptions = new();
    private List<string> regionOptions = new();

    private List<string> tourCityOptions = new();
    private List<string> countryOptions = new();

    protected override async Task OnInitializedAsync()
    {
        performance.Type = "Стационар";
        performance.StationaryId = 1;
        performance.SettlementType = "Город";
        performance.TourType = "Home";
        stationaryLocations = await _context.StationarLocations.ToListAsync();
    }

    private void OnTimeChanged(DateTime? dateTime)
    {
        if (dateTime.HasValue)
        {
            performance.SelectedTime = dateTime;
            StateHasChanged();
        }
    }

    private void OnTypeChanged(ChangeEventArgs e)
    {
        performance.Type = e.Value?.ToString();
        performance.StationaryId = null;
        performance.OnSiteId = null;
        performance.TourId = null;
    }

    private void OnTourTypeChanged(ChangeEventArgs e)
    {
        performance.TourType = e.Value?.ToString();
        performance.TourTownName = null;
        performance.Country = null;
    }
    private async Task LoadOnSiteNameOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            var lower = search.ToLower();
            var all = await _context.OnSiteLocations.ToListAsync();

            onSiteNameOptions = all
                .Where(l => l.TownName.ToLower().StartsWith(lower))
                .Select(l => l.TownName + ", " + l.Region + " (" + l.SettlementType + ")")
                .Distinct()
                .Take(10)
                .ToList();
        }
        else
            onSiteNameOptions.Clear();
    }

    private async Task LoadRegionOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            var lower = search.ToLower();
            var all = await _context.OnSiteLocations.ToListAsync();

            regionOptions = all
                .Where(l => l.Region.ToLower().StartsWith(lower))
                .Select(l => l.Region)
                .Distinct()
                .Take(10)
                .ToList();
        }
        else
            regionOptions.Clear();
    }

    private async void OnSiteNameInput(string value)
    {
        performance.OnSiteTownName = value;
        await LoadOnSiteNameOptions(value);
    }

    private void OnSiteNameSelected(string value)
    {
        var parts = value.Split(',');
        if (parts.Length >= 2)
        {
            performance.OnSiteTownName = parts[0].Trim();
            performance.Region = parts[1].Split('(')[0].Trim();
            performance.SettlementType = value.Contains("(Город)") ? "Город" : "Село";
        }
    }

    private async void OnRegionInput(string value)
    {
