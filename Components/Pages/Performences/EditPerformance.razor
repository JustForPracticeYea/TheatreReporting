    private void OnTypeChanged(ChangeEventArgs e)
    {
        performanceDto.Type = e.Value?.ToString();
        performanceDto.StationaryId = null;
        performanceDto.OnSiteId = null;
        performanceDto.TourId = null;
    }
    private void OnTourTypeChanged(ChangeEventArgs e)
    {
        performanceDto.TourType = e.Value?.ToString();
        performanceDto.TourTownName = null;
        performanceDto.Country = null;
    }
    private async Task LoadOnSiteNameOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            var lower = search.ToLower();
            var all = await _context.OnSiteLocations.ToListAsync();

            onSiteNameOptions = all
                .Where(l => l.TownName.ToLower().StartsWith(lower))
                .Select(l => l.TownName + ", " + l.Region + " (" + l.SettlementType + ")")
                .Distinct()
                .Take(10)
                .ToList();
        }
        else
            onSiteNameOptions.Clear();
    }

    private async Task LoadRegionOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            var lower = search.ToLower();
            var all = await _context.OnSiteLocations.ToListAsync();

            regionOptions = all
                .Where(l => l.Region.ToLower().StartsWith(lower))
                .Select(l => l.Region)
                .Distinct()
                .Take(10)
                .ToList();
        }
        else
            regionOptions.Clear();
    }

    private async void OnSiteNameInput(string value)
    {
        performanceDto.OnSiteTownName = value;
        await LoadOnSiteNameOptions(value);
    }

    private void OnSiteNameSelected(string value)
    {
        var parts = value.Split(',');
        if (parts.Length >= 2)
        {
            performanceDto.OnSiteTownName = parts[0].Trim();
            performanceDto.Region = parts[1].Split('(')[0].Trim();
            performanceDto.SettlementType = value.Contains("(Город)") ? "Город" : "Село";
        }
    }

    private async void OnRegionInput(string value)
    {
        performanceDto.Region = value;
        await LoadRegionOptions(value);
    }

    private async void OnRegionSelected(string value)
    {
        performanceDto.Region = value;
    }

    private async Task LoadTourCityOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            var lower = search.ToLower();

            if (performanceDto.TourType == "International")
            {
                tourCityOptions = await _context.TourLocations
                    .Where(l => l.TownName.ToLower().StartsWith(lower) && l.Country != "Россия")
                    .Select(l => l.TownName + ", " + l.Country)
                    .Distinct()
                    .Take(10)
                    .ToListAsync();
            }
            else
            {
                tourCityOptions = await _context.TourLocations
                    .Where(l => l.TownName.ToLower().StartsWith(lower) && l.Country == "Россия")
                    .Select(l => l.TownName)
                    .Distinct()
                    .Take(10)
                    .ToListAsync();
            }
        }
        else
            tourCityOptions.Clear();
    }

    private async Task LoadCountryOptions(string search)
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            var lower = search.ToLower();

            countryOptions = await _context.TourLocations
                .Where(l => l.Country.ToLower().StartsWith(lower) && l.Country != "Россия")
                .Select(l => l.Country)
                .Distinct()
                .Take(10)
                .ToListAsync();
        }
        else
            countryOptions.Clear();
    }

    private async void OnTourCityInput(string value)
    {
        performanceDto.TourTownName = value;
        await LoadTourCityOptions(value);
    }

    private async void OnTourCitySelected(string value)
    {
        if (performanceDto.TourType == "International")
        {
            var parts = value.Split(',');
            if (parts.Length >= 2)
            {
                performanceDto.TourTownName = parts[0].Trim();
                performanceDto.Country = parts[1].Trim();
            }
        }
        else
        {
            performanceDto.TourTownName = value;
            performanceDto.Country = "Россия";
        }
    }

    private async void OnCountryInput(string value)
    {
        performanceDto.Country = value;
        await LoadCountryOptions(value);
    }

    private async void OnCountrySelected(string value)
    {
        performanceDto.Country = value;
        var lower = value.ToLower();
        var loc = await _context.TourLocations
            .FirstOrDefaultAsync(l => l.Country.ToLower() == lower);
        if (loc != null)
        {
            performanceDto.TourTownName = loc.TownName;
        }
    }

    private async Task EditThisPerformance(EditContext context)
    {
        if (performance != null)
        {
            var eventDateTime = performanceDto.SelectedDate.Date + (performanceDto.SelectedTime?.TimeOfDay ?? TimeSpan.Zero);
            performance.PerformanceNumber = performanceDto.PerformanceNumber;
            performance.Type = performanceDto.Type;
            performance.EventDateTime = eventDateTime;

            performance.StationaryId = performanceDto.Type == "Стационар" ? performanceDto.StationaryId : null;
            performance.OnSiteId = null;
            performance.TourId = null;

            if (performanceDto.Type == "Выезд" && !string.IsNullOrWhiteSpace(performanceDto.OnSiteTownName))
            {
                var loc = await _context.OnSiteLocations.FirstOrDefaultAsync(l => l.TownName == performanceDto.OnSiteTownName && l.SettlementType == performanceDto.SettlementType);
                if (loc == null)
                {
                    loc = new OnSiteLocation { TownName = performanceDto.OnSiteTownName, SettlementType = performanceDto.SettlementType, Region = performanceDto.Region };
                    _context.OnSiteLocations.Add(loc);
                    await _context.SaveChangesAsync();
                }
                performance.OnSiteId = loc?.OnSiteId;
            }
            else if (performanceDto.Type == "Гастроль" && !string.IsNullOrWhiteSpace(performanceDto.TourTownName))
            {
                var country = performanceDto.TourType == "Home" ? "Россия" : performanceDto.Country;
                var loc = await _context.TourLocations.FirstOrDefaultAsync(l => l.TownName == performanceDto.TourTownName && l.Country == country);
                if (loc == null)
                {
                    loc = new TourLocation { TownName = performanceDto.TourTownName, Country = country }; _context.TourLocations.Add(loc);
                    await _context.SaveChangesAsync();
                }
                performance.TourId = loc?.TourId;
            }

            performance.NumTickCashOffice = performanceDto.NumTickCashOffice;
            performance.NumTickNonCashOffice = performanceDto.NumTickNonCashOffice;
            performance.NumTickCashOnline = performanceDto.NumTickCashOnline;
