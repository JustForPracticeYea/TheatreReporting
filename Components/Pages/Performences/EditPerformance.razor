@page "/{PlayId:int}/EditPerformance/{PerformanceId:int}"
@rendermode InteractiveServer
@using System.Globalization
@using TheatreReportingApp.DtoAndHelpers
@using TheatreReportingApp.Models
@inject TheatreDbContext _context
@inject NavigationManager Navigation

<h3 class="text-center">Редактирование спектакля</h3>
<div class="form-container">
    <div class="form-wrapper">
        <EditForm Model="@performanceDto" OnSubmit="@EditThisPerformance">
            <DataAnnotationsValidator />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Номер спектакля</label>
                        <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.PerformanceNumber" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Тип проведения</label>
                        <InputSelect class="form-control" @bind-Value="performanceDto.Type" @onchange="OnTypeChanged">
                            <option value="Стационар">Стационар</option>
                            <option value="Выезд">Выезд</option>
                            <option value="Гастроль">Гастроли</option>
                        </InputSelect>
                    </div>
                </div>
            </div>

            @if (performanceDto.Type == "Стационар")
            {
                <div class="form-group mb-3">
                    <label>Место проведения</label>
                    <InputSelect class="form-control" @bind-Value="performanceDto.StationaryId">
                        @foreach (var loc in stationaryLocations)
                        {
                            <option value="@loc.StationarId">@loc.LocationName</option>
                        }
                    </InputSelect>
                </div>
            }

            @if (performanceDto.Type == "Выезд")
            {
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Тип населенного пункта</label>
                            <InputSelect class="form-control" @bind-Value="performanceDto.SettlementType">
                                <option value="Город">Город</option>
                                <option value="Село">Село</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Название</label>
                            <AutoComplete class="form-control"
                                          Placeholder="Введите название..."
                                          Options="@onSiteNameOptions"
                                          @bind-Value="performanceDto.OnSiteTownName"
                                          OnInput="@(v => OnSiteNameInput(v.Value?.ToString()))"
                                          OnSelectionChange="@(v => OnSiteNameSelected(v.Label))" />
                        </div>
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label>Регион</label>
                    <AutoComplete class="form-control"
                                  Placeholder="Введите регион..."
                                  Options="@regionOptions"
                                  @bind-Value="performanceDto.Region"
                                  OnInput="@(v => OnRegionInput(v.Value?.ToString()))"
                                  OnSelectionChange="@(v => OnRegionSelected(v.Label))" />
                </div>
            }

            @if (performanceDto.Type == "Гастроль")
            {
                <div class="form-group mb-3">
                    <label>Тип гастролей</label>
                    <InputSelect class="form-control" @bind-Value="performanceDto.TourType" @onchange="OnTourTypeChanged">
                        <option value="Home">По России</option>
                        <option value="International">Зарубеж</option>
                    </InputSelect>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Город</label>
                            <AutoComplete class="form-control"
                                          Placeholder="Введите город..."
                                          Options="@tourCityOptions"
                                          Value="@performanceDto.TourTownName"
                                          OnInput="@(e => OnTourCityInput(e.Value?.ToString()))"
                                          OnSelectionChange="@(v => OnTourCitySelected(v.Label))" />
                        </div>
                    </div>
                    @if (performanceDto.TourType == "International")
                    {
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Страна</label>
                                <AutoComplete class="form-control"
                                              Placeholder="Введите страну..."
                                              Options="@countryOptions"
                                              Value="@performanceDto.Country"
                                              OnInput="@(e => OnCountryInput(e.Value?.ToString()))"
                                              OnSelectionChange="@(v => OnCountrySelected(v.Label))" />
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Дата проведения</label>
                        <AntDesign.DatePicker class="form-control w-50"
                                              DefaultValue="DateTime.Now"
                                              CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")"
                                              @bind-Value="performanceDto.SelectedDate" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Время проведения</label>
                        <TimePicker class="form-control w-50"
                                    ChangeOnClose="true"
                                    TValue="DateTime?"
                                    Picker="DatePickerType.Time"
                                    Format="HH:mm"
                                    CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")"
                                    @bind-Value="performanceDto.SelectedTime" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Продажа билетов на кассе</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickNonCashOffice" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Продажа билетов через интернет</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickNonCashOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Возвраты билетов</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickRetCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountFundsRetCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickRetNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountFundsRetNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickRetCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountFundsRetCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickRetNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountFundsRetNonCashOline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Реализованные билеты</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickSoldCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickSoldCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickSoldNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (касса/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickSoldNonCashOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickSoldCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/нал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickSoldCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Кол-во (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumTickSoldNonCashOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма (интернет/безнал)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AmountTickSoldNonCashOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Итоговые суммы</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого билетов (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AllNumTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого сумма (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AllAmountTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого билетов (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AllNumTickSoldOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Итого сумма (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.AllAmountTickSoldOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Реально получено (касса)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.RealAmountTickSoldInOffice" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Реально получено (интернет)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.RealAmountTickSoldInOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Итоги нал/безнал</h5>
                </div>
                <div class="card-body">
                    <h5>Продано</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalNumTickSoldCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAmountTickSoldCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalNumTickSoldNonCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAmountTickSoldNonCashInOfficeOnline" />
                            </div>
                        </div>
                    </div>
                    <h5 class="mt-3">Возвраты</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего возвратов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalNumTickRetCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма возвратов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAmountFundsRetCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего возвратов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalNumTickRetNonCashInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Сумма возвратов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAmountFundsRetNonCashInOfficeOnline" />
                            </div>
                        </div>
                    </div>
                    <h5 class="mt-3">Реализовано</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalNumTickSoldCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — нал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAmountTickSoldCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalNumTickSoldNonCashOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма — безнал</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAmountTickSoldNonCashOfficeOnline" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-card-header">
                    <h5 class="mb-0 text-white">Общий итог</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего билетов</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAllNumTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего сумма</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalAllAmountTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Всего реально получено</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.TotalRealAmountTickSoldInOfficeOnline" />
                            </div>
                        </div>
                        <div class="col-md-6"></div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Аншлаг (всего мест)</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.Capacity" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label>Максимальная сумма при аншлаге</label>
                                <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.MaxRevenue" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label>Зрителей бесплатно</label>
                        <AntDesign.InputNumber Min="0" Step="1" class="form-control" @bind-Value="performanceDto.NumViewrsServedFree" />
                    </div>
                </div>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a class="btn btn-secondary ms-2" @onclick="Cancel">Отмена</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public int PlayId { get; set; }
    [Parameter] public int PerformanceId { get; set; }

    private PerformanceDto performanceDto = new();
    private Performance performance;
    private List<StationarLocation> stationaryLocations = new();
    private List<string> onSiteNameOptions = new();
    private List<string> regionOptions = new();
    private List<string> tourCityOptions = new();
    private List<string> countryOptions = new();

    protected override async Task OnInitializedAsync()
    {
        stationaryLocations = await _context.StationarLocations.ToListAsync();
        performance = await _context.Performances.FindAsync(PerformanceId);

        performanceDto = new PerformanceDto
        {
            PerformanceNumber = performance.PerformanceNumber,
            Type = performance.Type,
            StationaryId = performance.StationaryId,
            OnSiteId = performance.OnSiteId,
            TourId = performance.TourId,
            SelectedDate = performance.EventDateTime.Date,
            SelectedTime = performance.EventDateTime,
            NumTickCashOffice = performance.NumTickCashOffice,
            NumTickNonCashOffice = performance.NumTickNonCashOffice,
            NumTickCashOnline = performance.NumTickCashOnline,
            NumTickNonCashOnline = performance.NumTickNonCashOnline,
            AmountTickCashOffice = performance.AmountTickCashOffice,
            AmountTickNonCashOffice = performance.AmountTickNonCashOffice,
            AmountTickCashOnline = performance.AmountTickCashOnline,
            AmountTickNonCashOnline = performance.AmountTickNonCashOnline,
            NumTickRetCashOffice = performance.NumTickRetCashOffice,
