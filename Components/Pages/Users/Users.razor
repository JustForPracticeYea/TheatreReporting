@page "/users"
@rendermode InteractiveServer
@using System.ComponentModel
@using System.ComponentModel.DataAnnotations
@using AntDesign.TableModels
@using Microsoft.AspNetCore.Authorization
@using TheatreReportingApp.Models
@using TheatreReportingApp.ViewModels
@inject ModalService ModalService;
@inject ConfirmService ComfirmService;
@inject TheatreDbContext _context;
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "Admin")]

<div class="controls-container">
    <PageHeader Class="site-page-header" Title="Список пользователей" />
    <a class="add-button" @onclick="() => AddUser()">
        <Icon Type="plus-square" Width="37px" Height="37px" />
    </a>
</div>
