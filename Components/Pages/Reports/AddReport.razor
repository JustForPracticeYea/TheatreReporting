@page "/AddReport"
@using Microsoft.AspNetCore.Authorization
@using TheatreReportingApp.Models
@using TheatreReportingApp.DtoAndHelpers
@using Microsoft.EntityFrameworkCore
@using TheatreReportingApp.Models.Enums
@rendermode InteractiveServer
@inject TheatreDbContext _context
@inject NavigationManager Navigation
@attribute [Authorize]

<h3 class="text-center">Создание отчёта</h3>
<div class="form-container-reports">
    <div class="form-wrapper">
        <div class="form-group mb-3">
            <label>Название отчёта</label>
            <Input class="form-control" @bind-Value="@report.Title" Placeholder="Введите название отчёта" />
        </div>

        <div class="form-group mb-3">
            <label>Тип отчёта</label>
            <InputSelect class="form-control" @bind-Value="@report.Type">
                <option value="Performances">По спектаклям</option>
                <option value="Authors">По авторам</option>
            </InputSelect>
        </div>

        @if (report.Type == ReportType.Performances)
        {
            <div class="form-group mb-3">
                <label>Категория</label>
                <InputSelect class="form-control" @bind-Value="@performanceFilter">
                    <option value="All">По всем</option>
                    <option value="Stationary">Стационар</option>
                    <option value="OnSite">Выезд</option>
                    <option value="Tour">Гастроли</option>
                </InputSelect>
            </div>

            @if (performanceFilter == PerformanceFilterType.Stationary)
            {
                <div class="form-group mb-3">
                    <label>Площадки</label>
                    <InputSelect class="form-control" @bind-Value="@stationaryFilter">
                        <option value="Все">По всем</option>
                        @foreach (var loc in stationaryLocations)
                        {
                            <option value="@loc">@loc</option>
                        }
                    </InputSelect>
                </div>
            }

            @if (performanceFilter == PerformanceFilterType.OnSite)
            {
                <div class="form-group mb-3">
                    <label>Тип населённого пункта</label>
                    <InputSelect class="form-control" @bind-Value="@onsiteFilter">
                        <option value="All">По всем</option>
                        <option value="City">Город</option>
                        <option value="Village">Село</option>
                    </InputSelect>
                </div>
            }

            @if (performanceFilter == PerformanceFilterType.Tour)
            {
                <div class="form-group mb-3">
                    <label>Тип гастролей</label>
                    <InputSelect class="form-control" @bind-Value="@tourFilter">
                        <option value="All">По всем</option>
                        <option value="Domestic">По России</option>
                        <option value="International">Зарубеж</option>
                    </InputSelect>
                </div>
            }
        

            @if (selectedPeriod != "Custom")
            {
                <div class="form-group mb-3">
                    <label>Дата, с которой формируется отчёт</label>
                    <AntDesign.DatePicker class="form-control w-50"
                                          CultureInfo="@System.Globalization.CultureInfo.GetCultureInfo("ru-Ru")"
                                          @bind-Value="@report.FromPeriod" />
                </div>
            }
            <div class="form-group mb-3">
                <label>Период</label>
                <div class="d-flex flex-wrap gap-2 mb-2">
                    <Button Type="@(selectedPeriod == "12M" ? ButtonType.Primary : ButtonType.Default)" OnClick="@(() => SetPeriod("12M"))">1 год</Button>
                    <Button Type="@(selectedPeriod == "9M" ? ButtonType.Primary : ButtonType.Default)" OnClick="@(() => SetPeriod("9M"))">9 мес</Button>
                    <Button Type="@(selectedPeriod == "6M" ? ButtonType.Primary : ButtonType.Default)" OnClick="@(() => SetPeriod("6M"))">6 мес</Button>
                    <Button Type="@(selectedPeriod == "3M" ? ButtonType.Primary : ButtonType.Default)" OnClick="@(() => SetPeriod("3M"))">3 мес</Button>
                    <Button Type="@(selectedPeriod == "1M" ? ButtonType.Primary : ButtonType.Default)" OnClick="@(() => SetPeriod("1M"))">1 мес</Button>
                    <Button Type="@(selectedPeriod == "Custom" ? ButtonType.Primary : ButtonType.Default)" OnClick="@(() => SetPeriod("Custom"))">Другое</Button>
                </div>
            </div>

            @if (selectedPeriod == "Custom")
            {
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>С даты</label>
                            <AntDesign.DatePicker class="form-control" 
                                                  CultureInfo="@System.Globalization.CultureInfo.GetCultureInfo("ru-Ru")" 
                                                  @bind-Value="@customStartDate" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>По дату</label>
                            <AntDesign.DatePicker class="form-control" 
                                                  CultureInfo="@System.Globalization.CultureInfo.GetCultureInfo("ru-Ru")" 
                                                  @bind-Value="@customEndDate" />
                        </div>
                    </div>
                </div>
            }
        }
        @if (report.Type == ReportType.Authors)
        {
            <div class="form-group mb-3">
                <label>Месяц, за который формируется отчёт</label>
                <AntDesign.DatePicker class="form-control w-50"
                                      Picker="DatePickerType.Month"
                                      CultureInfo="@System.Globalization.CultureInfo.GetCultureInfo("ru-Ru")"
                                      @bind-Value="@authorReportMonth" />
            </div>
        }

        <div class="alert alert-info">
            <strong>Период отчёта:</strong> @GetPeriodDescription()
        </div>

        <div class="form-group mt-3">
            <Button Type="@ButtonType.Primary" OnClick="@GenerateReport" Loading="@_isGenerating">Сформировать отчёт</Button>
            <Button OnClick="@Cancel" Class="ms-2">Отмена</Button>
        </div>
    </div>
</div>

@code {
    private Report report = new()
    {
        Title = $"Отчёт от {DateTime.Now:dd.MM.yyyy}",
        Type = ReportType.Performances,
        CreatedDate = DateTime.Now,
        FromPeriod = DateTime.Now,
        ToPeriod = DateTime.Now.AddMonths(1)
    };
    private string selectedPeriod = "1M";
    private DateTime customStartDate = DateTime.Now;
    private DateTime customEndDate = DateTime.Now.AddMonths(1);
    private bool _isGenerating;

    private DateTime authorReportMonth = DateTime.Now;
    private DateTime authorStartDate => new DateTime(authorReportMonth.Year, authorReportMonth.Month, 1);
    private DateTime authorEndDate => authorStartDate.AddMonths(1).AddDays(-1);
    private DateTime authorQueryEndDate => authorStartDate.AddMonths(1);

    private PerformanceFilterType performanceFilter = PerformanceFilterType.All;
    private TourFilterType tourFilter = TourFilterType.All;
    private string stationaryFilter = "Все";
    private List<string> stationaryLocations = new();
    private OnSiteFilterType onsiteFilter = OnSiteFilterType.All;

    private DateTime startDate => selectedPeriod == "Custom" ? customStartDate : report.FromPeriod;
    private DateTime endDate => selectedPeriod switch
    {
        "1M" => CalculateEndDate(1),
        "3M" => CalculateEndDate(3),
        "6M" => CalculateEndDate(6),
        "9M" => CalculateEndDate(9),
        "12M" => CalculateEndDate(12),
        _ => customEndDate
    };

    protected override async Task OnInitializedAsync()
    {
        stationaryLocations = await _context.StationarLocations.Select(s => s.LocationName).Distinct().ToListAsync();
    }

    private DateTime CalculateEndDate(int months)
    {
        var endDate = startDate.AddMonths(months);
        return startDate.Day == 1 ? endDate.AddDays(-1) : endDate;
    }

    private void SetPeriod(string period)
    { 
        selectedPeriod = period; 
    }

    private string GetPeriodDescription() => report.Type == ReportType.Authors ?
    $"За {authorReportMonth:MMMM yyyy} ({authorStartDate:dd.MM.yyyy} — {authorEndDate:dd.MM.yyyy})" :
    
    selectedPeriod switch
    {
        "1M" => $"1 месяц ({startDate:dd.MM.yyyy} — {endDate:dd.MM.yyyy})",
        "3M" => $"3 месяца ({startDate:dd.MM.yyyy} — {endDate:dd.MM.yyyy})",
        "6M" => $"6 месяцев ({startDate:dd.MM.yyyy} — {endDate:dd.MM.yyyy})",
        "9M" => $"9 месяцев ({startDate:dd.MM.yyyy} — {endDate:dd.MM.yyyy})",
        "12M" => $"1 год ({startDate:dd.MM.yyyy} — {endDate:dd.MM.yyyy})",
        _ => $"{customStartDate:dd.MM.yyyy} — {customEndDate:dd.MM.yyyy}"
    };

    private async Task GenerateReport()
    {
        _isGenerating = true;
        if (report.Type == ReportType.Authors)
        {
            report.FromPeriod = authorStartDate;
            report.ToPeriod = authorEndDate;
        }
        else
        {
            report.ToPeriod = endDate;
        }

        var metadata = new
        {
            performanceFilter = performanceFilter.ToString(),
            stationaryFilter,
            onsiteFilter,
            tourFilter = tourFilter.ToString(),
        };

        var content = new Dictionary<string, object> { ["metadata"] = metadata };

        if (report.Type == ReportType.Performances)
            content["data"] = await GetPerformancesData();
        else if (report.Type == ReportType.Authors)
            content["data"] = await GetAuthorsData();

        report.Content = System.Text.Json.JsonSerializer.Serialize(content,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true, Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping });

        report.UserId = _context.Users.Select(u => u.Id).FirstOrDefault();
        _context.Reports.Add(report);
        await _context.SaveChangesAsync();

        _isGenerating = false;
        Navigation.NavigateTo("/reports");
    }

    private async Task<PlayReportDataContainer> GetPerformancesData()
    {
        var query = _context.Performances.Where(p => p.EventDateTime >= startDate && p.EventDateTime <= endDate);

        query = performanceFilter switch
        {
            PerformanceFilterType.Stationary => query.Where(p => p.Type == PerformanceType.Stationary),
            PerformanceFilterType.OnSite => query.Where(p => p.Type == PerformanceType.OnSite),
            PerformanceFilterType.Tour => query.Where(p => p.Type == PerformanceType.Tour),
            _ => query
        };

        if (performanceFilter == PerformanceFilterType.Stationary && stationaryFilter != "Все")
            query = query.Where(p => p.Stationary.LocationName == stationaryFilter);

        if (performanceFilter == PerformanceFilterType.OnSite && onsiteFilter != OnSiteFilterType.All)
            query = query.Where(p => p.OnSite.SettlementType.ToString() == onsiteFilter.ToString());

        if (performanceFilter == PerformanceFilterType.Tour && tourFilter != TourFilterType.All)
            query = tourFilter == TourFilterType.Domestic ? query.Where(p => p.Tour.Country == "Россия") : query.Where(p => p.Tour.Country != "Россия");

        var performances = await query.Include(p => p.Play)
                                      .Include(p => p.PerformanceViewerCategories)
                                        .ThenInclude(v => v.ViewerCategory)
                                      .ToListAsync();

        var allPlays = await _context.Plays.OrderBy(p => p.Title).ToListAsync();

        var freeCategories = performances.SelectMany(p => p.PerformanceViewerCategories)
                                         .GroupBy(v => v.ViewerCategory.CategoryName)
                                         .Select(g => new FreeCategoryData
                                         {
                                             Category = g.Key,
                                             Count = g.Sum(v => v.ViewerCount)
                                         }).ToList();

        return new PlayReportDataContainer
        {
            TotalData = new PlayReportTotal
            {
                TotalPerformances = performances.Count,
                TotalAudience = performances.Sum(p => p.TotalAllNumTickSoldInOfficeOnline),
                GrossRevenue = performances.Sum(p => p.TotalAllAmountTickSoldInOfficeOnline),
                RealRevenue = performances.Sum(p => p.TotalRealAmountTickSoldInOfficeOnline),
                TotalTransferred = 0,
                TotalFreeAudience = freeCategories.Sum(f => f.Count),
                FreeAudienceByCategory = freeCategories
            },
            Plays = allPlays.Select(play =>
            {
                var pp = performances.Where(p => p.PlayId == play.PlayId).ToList();
                return new PlayReportData
                {
                    PlayTitle = play.Title,
                    PerformanceCount = pp.Count,
                    TotalAudience = pp.Sum(p => p.TotalAllNumTickSoldInOfficeOnline),
                    GrossRevenue = pp.Sum(p => p.TotalAllAmountTickSoldInOfficeOnline),
                    RealRevenue = pp.Sum(p => p.TotalRealAmountTickSoldInOfficeOnline),
                    Transferred = 0
                };
            }).ToList()
        };
    }

    private async Task<AuthorReportContainer> GetAuthorsData()
    {
        var performances = await _context.Performances
            .Where(p => p.EventDateTime >= authorStartDate && p.EventDateTime < authorQueryEndDate)
            .Include(p => p.Play)
                .ThenInclude(p => p.PlayAuthors)
                    .ThenInclude(pa => pa.Authors)
                        .ThenInclude(a => a.AuthorJob)
            .OrderBy(p => p.EventDateTime)
            .ToListAsync();

        var grouped = performances
            .GroupBy(p => p.Play.Title)
            .Select(g =>
            {
                var playPerformances = g.OrderBy(p => p.EventDateTime).ToList();

                var dates = playPerformances.Select(p => p.EventDateTime.ToString("dd.MM")).ToList();
                var datesFormatted = FormatDatesWithCount(playPerformances.Count, dates);

                var authors = playPerformances
                    .SelectMany(p => p.Play.PlayAuthors)
                    .DistinctBy(pa => pa.AuthorsId)
                    .ToList();

                var contractNumbers = string.Join("\n", authors.Select(a => a.ContractNumber));

                var percentages = string.Join("\n", authors.Select(a => $"{a.RoyaltyPercentage}%"));
                var fees = string.Join("\n", authors.Select(a =>
                {
                    var fee = playPerformances.Sum(p => p.TotalRealAmountTickSoldInOfficeOnline) * a.RoyaltyPercentage / 100;
                    return $"{fee:N0} ₽";
                }));
                var jobs = string.Join("\n", authors.Select(a => a.Authors.AuthorJob?.Title ?? ""));
                var names = string.Join("\n", authors.Select(a => $"{a.Authors.AuthorSurname} {a.Authors.AuthorName[0]}.{a.Authors.AuthorFathername[0]}."));

                var grossRevenue = playPerformances.Sum(p => p.TotalRealAmountTickSoldInOfficeOnline);
                var totalAuthorFee = fees.Any()
                    ? authors.Zip(fees.Split('\n'), (a, f) =>
                        playPerformances.Sum(p => p.TotalRealAmountTickSoldInOfficeOnline) * a.RoyaltyPercentage / 100).Sum()
                    : 0;

                return new AuthorReportData
                {
                    PerformanceCount = playPerformances.Count,
                    DatesFormatted = datesFormatted,
                    PlayTitle = g.Key,
                    ContractNumbers = contractNumbers,
                    RoyaltyPercentages = percentages,
                    AuthorFees = string.Join("\n", fees),
                    AuthorJobs = jobs,
                    AuthorNames = names,
                    GrossRevenue = grossRevenue,
                    AuthorFee = totalAuthorFee
                };
            })
            .OrderBy(r => r.DatesFormatted)
            .ToList();

        return new AuthorReportContainer
        {
            PeriodFrom = authorStartDate,
            PeriodTo = authorEndDate,
            Rows = grouped,
            TotalGrossRevenue = grouped.Sum(r => r.GrossRevenue),
            TotalAuthorFee = grouped.Sum(r => r.AuthorFee)
        };
    }

    private string FormatDatesWithCount(int count, List<string> dates)
    {
        var result = new List<string> { count.ToString() };

        for (int i = 0; i < dates.Count; i += 2)
        {
            if (i + 1 < dates.Count)
                result.Add($"{dates[i]}, {dates[i + 1]}");
            else
                result.Add(dates[i]);
        }

        return string.Join("\n", result);
    }

    private void Cancel() => Navigation.NavigateTo("/reports");
}