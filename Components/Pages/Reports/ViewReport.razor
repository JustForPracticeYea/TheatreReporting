@page "/ViewReport/{ReportId:int}"
@using ClosedXML.Excel
@using Microsoft.AspNetCore.Authorization
@using TheatreReportingApp.Models
@using TheatreReportingApp.DtoAndHelpers
@using Microsoft.EntityFrameworkCore
@using TheatreReportingApp.Models.Enums
@rendermode InteractiveServer
@inject TheatreDbContext _context
@inject NavigationManager Navigation
@attribute [Authorize]

@if (report == null)
{
    <p>Отчёт не найден</p>
}
else
{
    <PageHeader Class="site-page-header" Title="@report.Title" />

    <div class="mb-3">
        <p>
            <strong>Тип:</strong> @(report.Type switch
            {
                ReportType.Performances => "По спектаклям",
                ReportType.Authors => "По авторам",
                _ => report.Type.ToString()
            })
        </p>
        <p><strong>Период:</strong> @report.FromPeriod.ToString("dd.MM.yyyy") — @report.ToPeriod.ToString("dd.MM.yyyy")</p>
        <p><strong>Дата создания:</strong> @report.CreatedDate.ToString("dd.MM.yyyy HH:mm")</p>
    </div>

    @if (report.Type == ReportType.Performances)
    {
        <div class="mb-3">
            <Button OnClick="@ExportToExcel">
                <Icon Type="file-excel" /> Выгрузить в Excel
            </Button>
            <Button OnClick="@GoBack" Class="ms-2">Назад</Button>
        </div>
        <div class="form-container-reports">
            <div class="form-wrapper">
                <div class="card mb-3">
                    <div class="card-header bg-card-header">
                        <h5 class="mb-0 text-white">Сводка по спектаклям</h5>
                    </div>
                    <div class="card-body p-0 report-table">
                        <Table TItem="PlayReportData" DataSource="@playsData" PageSize="20">
                            <PropertyColumn Property="c => c.PlayTitle" Title="Название" />
                            <PropertyColumn Property="c => c.PerformanceCount" Title="Кол-во концертов" />
                            <PropertyColumn Property="c => c.TotalAudience" Title="Обслужено зрителей" />
                            <PropertyColumn Property="c => c.GrossRevenue" Title="Валовая сумма сбора" />
                            <PropertyColumn Property="c => c.RealRevenue" Title="Полученная сумма" />
                            <PropertyColumn Property="c => c.Transferred" Title="Перечислено" />
                        </Table>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header bg-card-header"><h5 class="mb-0 text-white">Общие итоги</h5></div>
                    <div class="card-body">
                        <div class="row mb-2">
                            <div class="col-md-3"><strong>Кол-во концертов</strong></div>
                            <div class="col-md-3"><strong>Обслужено зрителей</strong></div>
                            <div class="col-md-3"><strong>Обслужено зрителей бесплатно</strong></div>
                            <div class="col-md-3"><strong>Перечислено</strong></div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3">@totalData?.TotalPerformances</div>
                            <div class="col-md-3">@totalData?.TotalAudience</div>
                            <div class="col-md-3">@totalData?.TotalFreeAudience</div>
                            <div class="col-md-3">@totalData?.TotalTransferred.ToString("N0") ₽</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-md-6"><strong>Валовая сумма сбора</strong></div>
                            <div class="col-md-6"><strong>Полученная сумма</strong></div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">@totalData?.GrossRevenue.ToString("N0") ₽</div>
                            <div class="col-md-6">@totalData?.RealRevenue.ToString("N0") ₽</div>
                        </div>
                    </div>
                </div>

                @if (freeCategories.Any())
                {
                    <div class="card mb-3">
                        <div class="card-header bg-card-header">
                            <h5 class="mb-0 text-white">Бесплатно обслуженые зрители по категориям</h5>
                        </div>
                        <div class="card-body p-0 report-table">
                            <Table TItem="FreeCategoryData" DataSource="@freeCategories" PageSize="10">
                                <PropertyColumn Property="c => c.Category" Title="Категория" />
                                <PropertyColumn Property="c => c.Count" Title="Количество" />
                            </Table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (report.Type == ReportType.Authors)
    {
        <div class="mb-3">
            <Button Type="@ButtonType.Primary" OnClick="@ExportToExcel">
                <Icon Type="file-excel" /> Выгрузить в Excel
            </Button>
            <Button OnClick="@GoBack" Class="ms-2">Назад</Button>
        </div>

        <Table TItem="AuthorReportData" DataSource="@authorsData" PageSize="20">
            <PropertyColumn Property="c => c.Author" Title="Автор" />
            <PropertyColumn Property="c => c.TotalRoyalty" Title="Сумма отчислений (₽)" />
        </Table>

        <div class="card mt-4">
            <div class="card-header"><h5>Итого</h5></div>
            <div class="card-body">
                <strong>Всего авторов:</strong> @authorsData.Count<br />
                <strong>Общая сумма отчислений:</strong> @authorsData.Sum(a => a.TotalRoyalty).ToString("N0") ₽
            </div>
        </div>
    }
}

@code {
    [Parameter] public int ReportId { get; set; }

    private Report? report;
    private PlayReportTotal? totalData;
    private List<PlayReportData> playsData = new();
    private List<FreeCategoryData> freeCategories = new();
    private List<AuthorReportData> authorsData = new();

    protected override async Task OnInitializedAsync()
    {
        report = await _context.Reports.FindAsync(ReportId);
        if (report?.Content == null) return;

        using var doc = System.Text.Json.JsonDocument.Parse(report.Content);
        var root = doc.RootElement;
        var data = root.GetProperty("data");

        if (report.Type == ReportType.Performances)
        {
            var container = System.Text.Json.JsonSerializer.Deserialize<PlayReportDataContainer>(data.GetRawText(),
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            totalData = container!.TotalData;
            playsData = container.Plays;
            freeCategories = totalData.FreeAudienceByCategory;
        }
        else if (report.Type == ReportType.Authors)
        {
            authorsData = System.Text.Json.JsonSerializer.Deserialize<List<AuthorReportData>>(data.GetRawText(),
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
        }
    }

    private string excelSheetName
    {
        get
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(report!.Content);
                var meta = doc.RootElement.GetProperty("metadata");
                var performanceFilter = meta.GetProperty("performanceFilter").GetString();
                var stationaryFilter = meta.GetProperty("stationaryFilter").GetString();
                var onsiteFilter = meta.GetProperty("onsiteFilter").GetString();
                var tourFilter = meta.GetProperty("tourFilter").GetString();
                return performanceFilter switch
                {
                    "Stationary" when stationaryFilter == "Все" => "Стационар",
                    "Stationary" => $"Стационар - {stationaryFilter}",
                    "OnSite" when onsiteFilter == "Все" => "Выезд",
                    "OnSite" => $"Выезд - {onsiteFilter}",
                    "Tour" when tourFilter == "All" => "Гастроли",
                    "Tour" when tourFilter == "Domestic" => "Гастроли по России",
                    "Tour" => "Гастроли зарубеж",
                    _ => "Спектакли"
                };
            }
            catch
            {
                return "Отчёт";
            }
        }
    }

    private async Task ExportToExcel()
    {
        if (totalData == null || !playsData.Any()) return;

        using var workbook = new XLWorkbook();
        var ws = workbook.Worksheets.Add(excelSheetName);

        int row = 1;

        ws.Range(row, 1, row, 6).Merge().Value = "Владимирский областной театр кукол";
        ws.Row(row).Style.Font.SetBold().Font.FontSize = 14;
        ws.Range(row, 1, row, 6).Style.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Center);
        row++;

        ws.Range(row, 1, row, 6).Merge().Value = $"ОПЕРАТИВНАЯ СВОДКА за период с {report!.FromPeriod:dd.MM.yyyy} по {report.ToPeriod:dd.MM.yyyy}";
        ws.Row(row).Style.Font.SetBold().Font.FontSize = 12;
        ws.Range(row, 1, row, 6).Style.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Center);
        row += 2;

        var headers = new[] { "Название спектакля", "Количество концертов", "Обслужено зрителей", "Валовая сумма сбора", "Полученная сумма", "Перечислено" };
        for (int i = 0; i < headers.Length; i++)
        {
            ws.Cell(row, i + 1).Value = headers[i];
            ws.Cell(row, i + 1).Style.Font.SetBold();
            ws.Cell(row, i + 1).Style.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Center);
            ws.Cell(row, i + 1).Style.Border.SetOutsideBorder(XLBorderStyleValues.Thin);
        }
        row++;

        foreach (var play in playsData)
        {
            ws.Cell(row, 1).Value = play.PlayTitle;
            ws.Cell(row, 2).Value = play.PerformanceCount;
            ws.Cell(row, 3).Value = play.TotalAudience;
            ws.Cell(row, 4).Value = play.GrossRevenue;
            ws.Cell(row, 5).Value = play.RealRevenue;
            ws.Cell(row, 6).Value = play.Transferred;

            ws.Cell(row, 4).Style.NumberFormat.SetFormat("# ##0");
            ws.Cell(row, 5).Style.NumberFormat.SetFormat("# ##0");
            ws.Cell(row, 6).Style.NumberFormat.SetFormat("# ##0");

            for (int i = 1; i <= 6; i++)
                ws.Cell(row, i).Style.Border.SetOutsideBorder(XLBorderStyleValues.Thin);

            row++;
        }

        ws.Cell(row, 1).Value = "Итого";
        ws.Cell(row, 2).Value = totalData.TotalPerformances;
        ws.Cell(row, 3).Value = totalData.TotalAudience;
        ws.Cell(row, 4).Value = totalData.GrossRevenue;
        ws.Cell(row, 5).Value = totalData.RealRevenue;
        ws.Cell(row, 6).Value = totalData.TotalTransferred;

        ws.Cell(row, 4).Style.NumberFormat.SetFormat("# ##0");
        ws.Cell(row, 5).Style.NumberFormat.SetFormat("# ##0");
        ws.Cell(row, 6).Style.NumberFormat.SetFormat("# ##0");

        for (int i = 1; i <= 6; i++)
        {
            ws.Cell(row, i).Style.Font.SetBold();
            ws.Cell(row, i).Style.Border.SetOutsideBorder(XLBorderStyleValues.Thin);
        }

        row += 2;

        ws.Cell(row, 1).Value = "Обслужено бесплатно";
        ws.Cell(row, 1).Style.Font.SetBold();
        ws.Cell(row, 2).Value = totalData.TotalFreeAudience;
        ws.Cell(row, 3).Value = "зрителя";

        ws.Column(1).Width = 35;
        ws.Column(2).Width = 18;
        ws.Column(3).Width = 18;
        ws.Column(4).Width = 20;
        ws.Column(5).Width = 18;
        ws.Column(6).Width = 15;

        using var stream = new MemoryStream();
        workbook.SaveAs(stream);
        var base64 = Convert.ToBase64String(stream.ToArray());
        Navigation.NavigateTo($"data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}", true);
    }

    private void GoBack() => Navigation.NavigateTo("/reports");
}