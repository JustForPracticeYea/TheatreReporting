@using System.Globalization
@using TheatreReportingApp.Models
@inject TheatreDbContext _context

<Modal Title="@(IsEdit ? "Редактирование спектакля" : "Добавление спектакля")"
       Visible="@Visible"
       OnOk="HandleOk"
       OnCancel="HandleCancel"
       DestroyOnClose="true"
       ConfirmLoading="_isSubmitting"
       MaskClosable="false"
       Width="700">

    <Form Model="@Model"
          OnFinishFailed="@OnFinishFailed"
          OnFinish="@OnFinish"
          @ref="@FormRef">

        <div>
            @if (!string.IsNullOrEmpty(error))
            {
                <Alert Type="AlertType.Error" Message="@error" Banner />
            }
        </div>

        <FormItem Label="Введите название спектакля">
            <Input @bind-Value="@Model.Title" />
        </FormItem>

        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0">Авторы спектакля</h6>
            <Button OnClick="@AddAuthor" Disabled="@(Model.PlayAuthors.Count >= allAuthors.Count)">
                <Icon Type="plus" /> Добавить автора
            </Button>
        </div>

        @foreach (var author in Model.PlayAuthors)
        {
            var currentAuthor = author;
            <div class="mb-2">
                <label>Автор</label>
                <InputSelect class="form-control" @bind-Value="currentAuthor.AuthorsId">
                    <option value="0" disabled selected>Выберите автора</option>
                    @foreach (var a in allAuthors)
                    {
                        @if (a.AuthorId == currentAuthor.AuthorsId || !Model.PlayAuthors.Any(pa => pa.AuthorsId == a.AuthorId && pa != currentAuthor))
                        {
                            <option value="@a.AuthorId">
                                @a.AuthorSurname @a.AuthorName[0].@a.AuthorFathername[0]. (@a.AuthorJob.Title)
                            </option>
                        }
                    }
                </InputSelect>

                <label>%</label>
                <AntDesign.InputNumber TValue="decimal" Min="1" Max="100" Step="1" class="form-control" @bind-Value="currentAuthor.RoyaltyPercentage" />

                <label>№ договора</label>
                <Input class="form-control" @bind-Value="currentAuthor.ContractNumber" />

                <label>Дата начала контракта</label>
                <DatePicker class="form-control" @bind-Value="currentAuthor.ContractDate"
                            CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")" />

                <label>Дата окончания контракта</label>
                <DatePicker class="form-control" @bind-Value="currentAuthor.ContractEndDate"
                            CultureInfo="@CultureInfo.GetCultureInfo("ru-Ru")" />

                <Button Danger OnClick="@(() => RemoveAuthor(currentAuthor))">
                    <Icon Type="delete" />
                </Button>
            </div>
        }
    </Form>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public Play? EditPlay { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    private Play Model { get; set; } = new() { PlayAuthors = new List<PlayAuthors>() };
    private Form<Play> FormRef { get; set; }
    private string error = "";
    private bool _isSubmitting;
    private List<Authors> allAuthors = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Visible)
        {
            allAuthors = await _context.Authors.Include(a => a.AuthorJob).ToListAsync();

            if (IsEdit && EditPlay != null)
            {
                var playFromDb = await _context.Plays
                    .Include(p => p.PlayAuthors)
                    .FirstOrDefaultAsync(p => p.PlayId == EditPlay.PlayId);

                if (playFromDb != null)
                {
                    Model = new Play
                    {
                        PlayId = playFromDb.PlayId,
                        Title = playFromDb.Title,
                        PlayAuthors = playFromDb.PlayAuthors?.ToList() ?? new List<PlayAuthors>()
                    };
                }
            }
            else
            {
                Model = new Play { PlayAuthors = new List<PlayAuthors>() };
                error = "";
            }
        }
    }

    private async Task OnFinish(EditContext editContext)
    {
        if (_isSubmitting) return;
        _isSubmitting = true;

        try
        {
            if (string.IsNullOrWhiteSpace(Model.Title))
            {
                error = "Введите название";
                _isSubmitting = false;
                return;
            }

            Play play;
            if (IsEdit && EditPlay != null)
            {
                play = await _context.Plays
                    .Include(p => p.PlayAuthors)
                    .FirstOrDefaultAsync(p => p.PlayId == EditPlay.PlayId);

                if (play == null)
                {
                    error = "Спектакль не найден";
                    _isSubmitting = false;
                    return;
                }

                play.Title = Model.Title;

                var existingAuthors = await _context.PlayAuthors
                    .Where(pa => pa.PlayId == play.PlayId)
                    .ToListAsync();
                _context.PlayAuthors.RemoveRange(existingAuthors);
            }
            else
            {
                play = new Play { Title = Model.Title };
                _context.Plays.Add(play);
                await _context.SaveChangesAsync();
            }

            foreach (var author in Model.PlayAuthors.Where(a => a.AuthorsId > 0))
            {
                var newPlayAuthor = new PlayAuthors
                {
                    PlayId = play.PlayId,
                    AuthorsId = author.AuthorsId,
                    RoyaltyPercentage = author.RoyaltyPercentage,
                    ContractNumber = author.ContractNumber,
                    ContractDate = author.ContractDate,
                    ContractEndDate = author.ContractEndDate
                };
                _context.PlayAuthors.Add(newPlayAuthor);
            }

            await _context.SaveChangesAsync();

            await VisibleChanged.InvokeAsync(false);
            await OnSuccess.InvokeAsync();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void OnFinishFailed(EditContext editContext)
    {
        error = "Заполните обязательные поля";
    }

    private async Task HandleOk()
    {
        if (FormRef != null)
        {
            FormRef.Submit();
        }
    }

    private void AddAuthor()
    {
        if (Model.PlayAuthors.Count < allAuthors.Count)
            Model.PlayAuthors.Add(new PlayAuthors());
    }

    private void RemoveAuthor(PlayAuthors author)
    {
        Model.PlayAuthors.Remove(author);
    }

    private async Task HandleCancel()
    {
        await VisibleChanged.InvokeAsync(false);
    }
}