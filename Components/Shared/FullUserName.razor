@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using TheatreReportingApp.Models
@inject TheatreDbContext _context
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@attribute [Authorize]

<NavLink href="@($"UserProfile/{userId}")">@FullName</NavLink>

@code {
    private string FullName = "Загрузка...";
    private string userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            var user = await _context.Users
                .Where(u => u.Id == userId)
                .Select(u => new { u.Surname, u.Name, u.Fathername })
                .FirstOrDefaultAsync();

            if (user != null)
            {
                FullName = $"{user.Surname} {user.Name[0]}. {user.Fathername[0]}.".Trim();
                if (string.IsNullOrEmpty(FullName))
                    FullName = authState.User.Identity?.Name ?? "Пользователь";
            }
        }
    }
}